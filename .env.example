# Copiar este archivo a .env y ajustar valores según el entorno.
# IMPORTANTE: dentro de docker-compose, el host de la base de datos es
# "db" (nombre del servicio), no "localhost".

DATABASE_URL=mysql+aiomysql://root:root@db:3306/pacientes_db
DB_ECHO=false
ENVIRONMENT=development

# JWT
JWT_SECRET_KEY=cambia-este-secreto-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
