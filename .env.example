# Copiar este archivo a .env y ajustar valores según el entorno.
# IMPORTANTE: dentro de docker-compose, el host de la base de datos es
# "db" (nombre del servicio), no "localhost".

DATABASE_URL=mysql+aiomysql://root:passw@tokaido.proxy.rlwy.net:20337/pa_db
DB_ECHO=false
ENVIRONMENT=development

# JWT
JWT_SECRET_KEY=cambia-este-secreto-en-produccion
JWT_ALGORITHM=HS256
# 7 dias (10080 min): ver nota en settings.py sobre por qué el token
# necesita vida larga en un contexto offline-first.
JWT_EXPIRE_MINUTES=10080
